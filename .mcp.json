{
  "mcpServers": {
    "poppy-data": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/services/mcp-server/dist/server.mjs"],
      "env": {
        "POPPY_API_URL": "${user_config.api_url}",
        "POPPY_API_TOKEN": "${user_config.api_token}"
      }
    }
  }
}
